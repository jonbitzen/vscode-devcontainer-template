{
    "name": "devcontainer-template",
    "build":{
         "dockerfile": "Dockerfile"
    },
    "remoteUser": "ubuntu",
    "runArgs": [
        "--net", "host",
        "--group-add", "video",

        // use a debugger inside the devcontainer
        "--cap-add=SYS_PTRACE", "--security-opt", "seccomp=unconfined",

        // run X11 apps; need either nvidia container toolkit or AMD container toolkit 
        "--ipc", "host",
        "--gpus", "all",
        "-v", "/tmp/.X11-unix:/tmp/.X11-unix",
        "-v", "/usr/share/icons:/usr/share/icons",
        "-v", "${localEnv:XDG_RUNTIME_DIR}:${localEnv:XDG_RUNTIME_DIR}",

        "-e", "DISPLAY=${env:DISPLAY}",
        "-e", "QT_X11_NO_MITSHM=1",
        "-e", "DBUS_SESSION_BUS_ADDRESS=${localEnv:DBUS_SESSION_BUS_ADDRESS}",
        "-e", "/var/run/dbus/system_bus_socket:/var/run/dbus/system_bus_socket",
        "-e", "XDG_RUNTIME_DIR=${localEnv:XDG_RUNTIME_DIR}",
        "-e", "NVIDIA_DRIVER_CAPABILITIES=all"
    ],
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash"
            },
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cpptools-extension-pack",
                "ms-vscode.cmake-tools", 
                "donjayamanne.githistory", 
                "ms-python.python",
                "ms-python.vscode-pylance", 
                "ms-azuretools.vscode-docker"
            ]
        }
    }
}